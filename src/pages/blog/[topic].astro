---
import topics from "@data/topics.json";

import BentoBoxGrid from "@components/building-blocks/wrappers/bento-box-grid/BentoBoxGrid.astro";
import Split from "@components/building-blocks/wrappers/split/Split.astro";
import ExploreTopics from "@components/page-sections/blog/sidebar/ExploreTopics.astro";
import PopularArticles from "@components/page-sections/blog/sidebar/PopularArticles.astro";
import CustomSection from "@components/page-sections/builders/custom-section/CustomSection.astro";
import CtaCenter from "@components/page-sections/ctas/cta-center/CtaCenter.astro";
import HeroSearch from "@components/page-sections/heroes/hero-search/HeroSearch.astro";
import Page from "@layouts/Page.astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

export interface Props {
  page: CollectionEntry<"pages">;
}

export async function getStaticPaths() {
  return topics.map((topic) => ({
    params: { topic: topic.name },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const posts = await getCollection('blog', ({ data }) => {
  return data.topic === topic.name;
});
---

<Page
  
>
  <HeroSearch 
    heading={topic.name}
    description={topic.description}
    backgroundColor="brand-linear-gradient-strong"
    variation="left-right"
  />

  <CustomSection
    maxContentWidth="2xl"
    paddingHorizontal="lg"
    paddingVertical="xl"
    colorScheme="inherit"
    backgroundColor="base"
    class="search-container"
  >
    {
      posts.map(post => post)
    }
  </CustomSection>
  
</Page>

<style is:global>
  .content > .split > .split-inner > .pane.second{
    gap: 32px;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 100px;
    align-self: start;
    max-height: 100vh;
    overflow-y:scroll;
  }

  .feature-date-container,
  .feature-date {
    margin-top: 0;
    color: #5a5a5a;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .feature-date-container {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--font-size-sm);
    * {
      font-size: var(--font-size-sm);
      color: #5a5a5a;
    }

    & svg > * {
      stroke: #5a5a5a;
    }
  }

  .blog-card {
    background: var(--color-bg-muted);
    padding: 24px;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
  }
</style>