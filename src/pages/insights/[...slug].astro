---
import Icon from "@components/building-blocks/core-elements/icon/Icon.astro";
import Input from "@components/building-blocks/forms/input/Input.astro";
import Split from "@components/building-blocks/wrappers/split/Split.astro";
import ExploreTopics from "@components/page-sections/blog/sidebar/ExploreTopics.astro";
import PopularArticles from "@components/page-sections/blog/sidebar/PopularArticles.astro";
import TableOfContents from "@components/page-sections/blog/sidebar/TableOfContents.astro";
import CtaCenter from "@components/page-sections/ctas/cta-center/CtaCenter.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Page from "@layouts/Page.astro";
import CustomSection from "@page-sections/builders/custom-section/CustomSection.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

import SocialBar from "@components/page-sections/blog/SocialBar.astro";
import Button from "@components/building-blocks/core-elements/button/Button.astro";
import BentoBoxGrid from "@components/building-blocks/wrappers/bento-box-grid/BentoBoxGrid.astro";
import BentoBoxGridItem from "@components/building-blocks/wrappers/bento-box-grid/BentoBoxGridItem.astro";
import Card from "@components/building-blocks/wrappers/card/Card.astro";
import { getEntry } from "astro:content";
import readingTime from "@components/utils/readingTime";

// Automatically import all components from building-blocks and page-sections for MDX
const buildingBlocksImports = import.meta.glob("../../components/building-blocks/**/*.astro", {
  eager: true,
});

const pageSectionsImports = import.meta.glob("../../components/page-sections/**/*.astro", {
  eager: true,
});

// Merge both import objects
const componentImports = { ...buildingBlocksImports, ...pageSectionsImports };

// Build components object with PascalCase names from file paths
const mdxComponents: Record<string, any> = {};

Object.entries(componentImports).forEach(([path, module]) => {
  const pathParts = path.split("/");
  const fileName = pathParts[pathParts.length - 1].replace(".astro", "");

  // Component name is already PascalCase from filename
  const componentName = fileName;

  mdxComponents[componentName] = (module as any).default;
});

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post: CollectionEntry<"blog">) => {
    const slug = post.id?.replace(/\.mdx?$/, "") || post.slug;

    return {
      params: { slug },
      props: { post },
    };
  });
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const WPM = 200;
const countWords = (str) => str.trim().split(/\s+/).length;

const content = post?.body;

if (post) post.data.minutesRead = `${Math.ceil(countWords(content) / WPM)} min read`;
---

<Page
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
>
  <CustomSection
    maxContentWidth="2xl"
    paddingHorizontal="lg"
    paddingVertical="none"
    colorScheme="inherit"
    backgroundColor="muted"
    backgroundImage={
      {
        "source":"/src/assets/images/Service Mark.svg",
        "positionHorizontal":"right"
      }
    }
    class="breadcrumb-container"
  >
    <div class="breadcrumb">
      Home
      <Icon
        name="chevron-right"
        size="none"
      />
      Insights
      <Icon
        name="chevron-right"
        size="none"
      />
      <a href={`/blog/${post.data.topic}`}>{post.data.topic}</a>
      <Icon
        name="chevron-right"
        size="none"
      />
      {post.data.title}
    </div>
    <Input
      name="search"
      placeholder="Search by keyword, topic..."
      type="text"
      iconName="magnifying-glass"
      iconPosition="after"
    />
  </CustomSection>

  <CustomSection
    maxContentWidth="2xl"
    paddingHorizontal="lg"
    paddingVertical="xl"
    colorScheme="inherit"
    backgroundColor="base"
    class="post-container"
  >
    <Split
      distributionMode="two-thirds-third"
      gap="xl"
    >
      <Fragment slot="first">
        <div class="topic-pill">
          {post.data.topic}
        </div>
        <Heading
          data-prop="title"
          level="h1"
          size="lg"
          style="margin-bottom: var(--spacing-xs);"
          data-pagefind-meta={`date:${post.data.date}`}
        >
          {post.data.title}
        </Heading>
        {
          post.data.description && (
            <SimpleText
              data-prop="description"
              size="lg"
              style="color: var(--color-text-muted); margin-bottom: 0; margin-top: var(--spacing-xs);"
            >
              {post.data.description}
            </SimpleText>
          )
        }
        <div class="date-socials">
          <div
            class="feature-date-container"
            data-cloudcannon-ignore
          >
            <Icon
              name="calendar"
              size="none"
            />
            <SimpleText
              alignX="start"
              size="md"
              class="feature-date"
              editable={false}
              data-cloudcannon-ignore
            >
              {
                new Date(post.data.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })
              }

              <Icon
                name="clock"
                size="none"
              />
              {post?.data.minutesRead ?? ""}
            </SimpleText>
          </div>

          <SocialBar size="lg" />
        </div>

        {
          post.data.image && (
            <Image
              source={post.data.image}
              alt={post.data.title}
              rounded={true}
              data-prop-src="image"
              data-prop-alt="title"
              class="post-image"
              aspectRatio="widescreen"
              positionVertical="center"
            />
          )
        }

        <div
          data-pagefind-body
          class="post"
          data-editable="text"
          data-prop="@content"
        >
          <Content components={mdxComponents} />
        </div>

        <div class:list={["share-bar"]}>
          Learned something new? Share it with a friend!
          <SocialBar size="xl" />
        </div>

        <div class:list={["prev-next-buttons"]}>
          <Button variant="tertiary" iconName="arrow-left" iconPosition="before" >
            Previous Article
          </Button>
          
          <Button variant="tertiary" iconName="arrow-right" iconPosition="after">
            Next Article
          </Button>
        </div>
      </Fragment>
      <Fragment slot="second">
        <TableOfContents headings={headings} />

        <PopularArticles />

        <ExploreTopics topic={post.data.topic} />

        <CtaCenter
          image="/src/assets/images/img_moneyhand.png"
          heading="Need extra cash?"
          subtext="A simple, secure way to cover urgent expenses."
          backgroundColor="muted"
          rounded={true}
          paddingHorizontal="none"
          paddingVertical="none"
          buttonSections={[
            {
              _component: "building-blocks/core-elements/button",
              text: "Apply Now",
              hideText: false,
              link: "",
              iconName: "",
              iconPosition: "before",
              variant: "primary",
              size: "md",
            },
          ]}
        />
      </Fragment>
    </Split>
  </CustomSection>

  <CustomSection
    maxContentWidth="2xl"
    paddingHorizontal="lg"
    paddingVertical="2xl"
    colorScheme="inherit"
    backgroundColor="muted"
  >
    <Heading level="h2" size="md">
      Related Articles
    </Heading>
    <BentoBoxGrid>
      { post.data.related_articles.map(async article => {
        article = article.replace("/src/content/blog/","").replace(".mdx","")
        const post = await getEntry('blog', article);

        return <BentoBoxGridItem
          columnSpan={3}
          rowSpan={1}
        >
          <Card
            backgroundColor="base"
            rounded={true}
            link={`/blog/${post?.id}`}
            paddingHorizontal="md"
            paddingVertical="md"
          >
            <Fragment slot="before">
              <Image source={post?.data.image} aspectRatio="landscape" />
            </Fragment>
            <Heading level="h3" size="sm" 
              style="
                margin-bottom:0;
                overflow: hidden;
                display: -webkit-box;
                -webkit-box-orient: vertical;
                -webkit-line-clamp: 2;
                line-clamp: 2;
              "
            >
              {post?.data.title}
            </Heading>
            <SimpleText 
              style="
                margin-top:0;
                overflow: hidden;
                display: -webkit-box;
                -webkit-box-orient: vertical;
                -webkit-line-clamp: 2;
                line-clamp: 2;
              "
            >
              {post?.data.description}
            </SimpleText>
            <div class="feature-date-container" data-cloudcannon-ignore>
              <Icon name="calendar" size="none" />
              <SimpleText
                alignX="start"
                size="sm"
                class="feature-date"
                editable={false}
                data-cloudcannon-ignore
              >
                { new Date(post.data.date).toLocaleDateString('en-US', {
                  //year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                }) }
                <Icon name="clock" size="none" />
                { readingTime(post)}
              </SimpleText>
            </div>
          </Card>
        </BentoBoxGridItem>
        })
      }
    </BentoBoxGrid>
  </CustomSection>
</Page>

<style is:global>
  .breadcrumb-container {
    .background-image{
      img{
        object-fit:contain;
      }
    }
    .outer-content {
      padding: 24px 0;
      .content {
        display: flex;
        align-items: center;
        justify-content: space-between;

        .breadcrumb {
          align-items: center;
          display: flex;
          font-size: var(--font-size-xs);
          gap: 8px;
        }

        .input {
          width: fit-content;
        }
      }
    }
  }

  .post {
    margin-inline: auto;
    margin-top: var(--spacing-xl);
  }

  .post > * {
    grid-column: 2;
  }

  .post > .wide,
  .post > pre,
  .post > .image,
  .post > .video {
    grid-column: 1 / -1;
  }

  .post > h1,
  .post > h2,
  .post > h3,
  .post > h4,
  .post > h5,
  .post > h6 {
    margin-bottom: 0;
    margin-top: 1rem;

    &:first-child {
      margin-top: 0;
    }
  }

  .post > h2 {
    font-size: var(--font-size-xl);
  }

  .post > ul{
    list-style:inside;
    padding:0;
    ::marker {
      color: var(--color-brand);
    }

    & > li{
      padding-bottom:16px;
    }
  }

  .post > .astro-code {
    margin-block: var(--spacing-xl);
  }

  .post-image {
    margin-top: var(--spacing-xl);
  }

  .topic-pill {
    background: var(--color-bg-brand);
    color: white;
    display: inline-flex;
    justify-content: flex-start;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-weight: bold;
    font-size: var(--font-size-xs);
  }

  .date-socials{
    display:flex;
    justify-content: space-between;
    border-bottom:1px solid var(--color-border-subtle);
    padding:16px 0;
  }

  .feature-date-container,
  .feature-date {
    margin-top: 0;
    color: #5a5a5a;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .feature-date-container {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--font-size-sm);
    * {
      font-size: var(--font-size-sm);
      color: #5a5a5a;
    }

    & svg > * {
      stroke: #5a5a5a;
    }
  }

  .social-container{
    display: flex;
    gap:8px;
  }

  .content > .split > .split-inner > .pane.second{
    gap: 32px;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 100px;
    align-self: start;
    max-height: 1000vh;
  }

  .blog-card {
    background: var(--color-bg-muted);
    padding: 24px;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
  }

  .share-bar{
    display:flex;
    align-items: center;
    border-bottom: 1px solid var(--color-border-subtle);
    border-top: 1px solid var(--color-border-subtle);
    justify-content: space-between;
    margin:32px 0;
    padding:32px 0;
  }

  .prev-next-buttons{
    display:flex;
    align-items: center;
    justify-content: space-between;

    & a{
      justify-content: flex-start;
      padding:20px;
      gap:12px;
      border-color:var(--color-border-subtle);

      & .icon{
        width:40px;
        height:40px;
        border-radius: 100%;
        display:flex;
        align-items: center;
        justify-content: center;
        background:#F3F4F6;
      }
    }
  }
</style>
