---
import RenderBlock from "@components/utils/renderBlock.astro";

const {
  contentSections,
  editable = false,
  class: className,
  style: userStyle,
  columnSpan = 4,
  rowSpan = 1,
  border = false,
  padding = "md",
  _component,
  "data-children-prop": childrenDataProp,
  ...htmlAttributes
} = Astro.props;

const effectiveChildrenProp = childrenDataProp ?? (editable ? "contentSections" : null);
const arrayDataAttributes = effectiveChildrenProp
  ? { "data-editable": "array", "data-prop": effectiveChildrenProp }
  : {};
---

<div
  class:list={["bento-box-grid-item", className]}
  {...htmlAttributes}
>
  <div
    class:list={["bento-box-grid-item-content", border && "with-border", `pad-${padding}`]}
    style={`--column-span: ${columnSpan}; --row-span: ${rowSpan}; ${userStyle ?? ""}`}
    {...arrayDataAttributes}
  >
    <slot>
      {
        contentSections && (
          <RenderBlock
            contentSections={contentSections}
            editable={!!effectiveChildrenProp}
          />
        )
      }
    </slot>
  </div>
</div>

<style>
  @layer components {
    .bento-box-grid-item {
      display: contents;

      :global(.pane.second){
        gap:8px!important;
      }
    }

    .bento-box-grid-item > .bento-box-grid-item-content {
      container-type: inline-size;
      grid-column: 1 / -1;
      grid-row: span var(--row-span, 1);
      height: 100%;

      &-pad-none{
        padding:0;
      }

      &.pad-sm{
        padding:8px;
      }

      &.pad-md{
        padding:16px;
      }

      @media (width >= 640px) {
        grid-column: span calc(var(--column-span, 4) * 2);
      }

      @media (width >= 900px) {
        grid-column: span var(--column-span, 4);
      }

      
    }

    .bento-box-grid-item > .bento-box-grid-item-content > *:only-child {
      height: 100%;
    }

    .bento-box-grid-item > .bento-box-grid-item-content > *:first-child {
      margin-top: 0 !important;
    }
  }
</style>
