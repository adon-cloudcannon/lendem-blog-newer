---
import Icon from "@components/building-blocks/core-elements/icon/Icon.astro";
import List from "@core-elements/list/List.astro";
import ListItem from "@core-elements/list/ListItem.astro";

const { headings } = Astro.props;
---

<div class="table-of-contents">
    <div class="list-item list-heading">
        <Icon name="book-open" size="md" />
        In this article
    </div>
    <List alignX="start" direction="vertical">
    {
        headings.map((heading,index) =>
            <ListItem class:list={[index === 0 ? "active" : ""]} >
                <Icon name="chevron-right" size="sm" />
                {heading.text}
            </ListItem>
        )
    }
    </List>
</div>
<style is:global>
    .table-of-contents{
        background:var(--color-bg-muted);
        border:1px solid var(--color-border-subtle);
        border-radius: var(--radius-sm);

        .list{
            margin-top:0;

            & ul{ gap: 0; }
        }

        .list-item, .item-inner{
            align-items: center;
            display:flex;
            font-size: var(--font-size-sm);
            gap:8px;
            padding:12px 16px;

            &.list-heading{
                font-family: "Poppins";
                font-weight:600;
            }
        }

        .item.active{
            background: var(--color-bg-surface);
            border-left: 2px solid var(--color-border-strong);
            color: var(--color-brand);
        }
    }
</style>