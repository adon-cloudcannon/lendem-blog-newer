---
import Heading from "@components/building-blocks/core-elements/heading/Heading.astro";
import Image from "@components/building-blocks/core-elements/image/Image.astro";
import BentoBoxGridItem from "@components/building-blocks/wrappers/bento-box-grid/BentoBoxGridItem.astro";
import Card from "@components/building-blocks/wrappers/card/Card.astro";
import Split from "@components/building-blocks/wrappers/split/Split.astro";
import FeatureDate from "./FeatureDate.astro";

const { 
  post,
  columnSpan = "12",
  background = "white",
  size = "md",
  borderless = false,
} = Astro.props;
---

<BentoBoxGridItem
  columnSpan={columnSpan}
  rowSpan={1}
  class:list={["article-card-horizontal",`bg-${background}`, borderless ? "borderless" : "bordered"]}
  padding={borderless ? "none" : size}
>
  <Card
    paddingVertical="none"
    style="margin-top:0"
    link={`/insights/${post?.id}`}
    data-pagefind-field="link"
  >
    <Split
      verticalAlignment="center"
      distributionMode="fixed-flexible"
      style="margin-top:0"
      fixedWidth={size == "md" ? 128 : 80}
      gap={size == "md" ? "lg" : "md"}
      responsive={false}
    >
      <Fragment slot="first">
        <Image
          source={post?.data.image || "/placeholder-image.jpg"}
          aspectRatio="square"
          data-pagefind-field="image"
        />
      </Fragment>
      <Fragment slot="second">
        <Heading
          level="h3"
          size={size == "md" ? "xs" : "xxs"}
          style="margin-bottom:8px"
          data-pagefind-field="title"
        >
          {post?.data.title}
        </Heading>
        <FeatureDate post={post} size="xs" data-pagefind-field="date" />
      </Fragment>
    </Split>
  </Card>
</BentoBoxGridItem>

<style>
  .article-card-horizontal{
    &.bg-white{
      :global(.bento-box-grid-item-content){
        background:white;
      }
    }

    &.borderless:not(:last-of-type){
      :global(.bento-box-grid-item-content){
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--color-border-subtle)!important;
      }
    }

    &.bordered{
      :global(.bento-box-grid-item-content){
        border-radius: var(--radius-xs);
        border: 1px solid var(--color-border-subtle);
      }
    }

    cursor:pointer;

    :global(.bento-box-grid-item-content){
      overflow: hidden;

      &:hover{
        border-color:var(--color-border-strong);

        :global(.heading-text){
          color:var(--color-bg-brand);
        }
      }
    
      :global(.split-inner){
        & .pane.second{ 
          & h3, & p, & .text{
            margin:0!important;
          }
        }
      }
    }
  }
</style>