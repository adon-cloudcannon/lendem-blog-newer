---
import Icon from "@components/building-blocks/core-elements/icon/Icon.astro";
import List from "@core-elements/list/List.astro";
import ListItem from "@core-elements/list/ListItem.astro";

import { slugifyLabel } from "@components/utils/slugify";

const { headings } = Astro.props;
---

<div class="table-of-contents">
    <div class="list-item list-heading">
        <Icon name="book-open" size="none" />
        In this article
    </div>
    <List alignX="start" direction="vertical">
    {
        headings.map((heading:any,index:number) =>
            <ListItem 
                class:list={[index === 0 && "active"]} 
                link={`#${slugifyLabel(heading.text)}`}
                iconName="chevron-right"
            >
                {heading.text}
            </ListItem>
        )
    }
    </List>
    <script>
        const articleSections = document.querySelectorAll<HTMLElement>(".post h2");

        let currentActiveId: string | null = null;

        const observer = new IntersectionObserver((entries) => {
            const visible = entries
                .filter(entry => entry.isIntersecting)
                .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

            if (visible.length === 0) return;

            const candidate = visible[0];
            const id = candidate.target.getAttribute("id");
            if (!id) return;

            if (currentActiveId === id) return;

            currentActiveId = id;

            document
                .querySelectorAll(".table-of-contents .item.active")
                .forEach(el => el.classList.remove("active"));

            const link = document.querySelector<HTMLAnchorElement>(
                `.table-of-contents a[href="#${id}"]`
            );

            link?.closest(".item")?.classList.add("active");
        }, {
            rootMargin: "0px 0px -60% 0px",
            threshold: [0],
        });

        articleSections.forEach(section => observer.observe(section));
    </script>
</div>
<style is:global>
    .table-of-contents{
        background:var(--color-bg-muted);
        border:1px solid var(--color-border-subtle);
        border-radius: var(--radius-sm);

        .list{
            margin-top:0;

            & ul{ 
                gap: 0;
                
                & a{
                    color:inherit;
                    text-decoration: none;
                }
            }
        }

        .list-item, .item-inner{
            align-items: center;
            display:flex;
            font-size: var(--font-size-sm);
            gap:8px;
            padding:12px 16px;

            &.list-heading{
                font-family: "Poppins";
                font-weight:600;
            }
        }

        .item{
            &:hover{
                cursor:pointer;
                background:var(--color-bg-hover);
            }
            &.active{
                background: var(--color-bg-surface);
                border-left: 2px solid var(--color-border-strong);
                color: var(--color-brand);
            }
        }

        @container (max-width: 700px) {
            display: none;
        }
    }
</style>