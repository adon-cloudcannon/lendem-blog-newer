---
import Icon from "@components/building-blocks/core-elements/icon/Icon.astro";
import List from "@core-elements/list/List.astro";
import ListItem from "@core-elements/list/ListItem.astro";

import { slugifyLabel } from "@components/utils/slugify";

const { headings } = Astro.props;
---

<div class="table-of-contents">
    <div class="list-item list-heading">
        <Icon name="book-open" size="none" />
        In this article
    </div>
    <List alignX="start" direction="vertical">
    {
        headings.map((heading:any,index:number) =>
            <ListItem class:list={[index === 0 ? "active" : ""]} >
                <a href={`#${slugifyLabel(heading.text)}`}>
                    <Icon name="chevron-right" size="none" />
                    {heading.text}
                </a>
            </ListItem>
        )
    }
    </List>
    <script>
        const articleSections = document.querySelectorAll<HTMLDivElement>(".post h2");

        const observer = new IntersectionObserver((entries) => {
            // Get all currently intersecting entries
            const visible = entries
                .filter(entry => entry.isIntersecting)
                // Sort by vertical position (top of viewport)
                .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

            if (visible.length === 0) return;

            // Pick the "best" one
            // Option A: closest to top
            const activeEntry = visible[0];

            // Option B (your idea): pick the next one down
            // const activeEntry = visible[visible.length - 1];

            const id = activeEntry.target.getAttribute("id");
            if (!id) return;

            // Remove all active states
            document
                .querySelectorAll(".table-of-contents .item.active")
                .forEach(el => el.classList.remove("active"));

            // Add active to the chosen one
            const link = document.querySelector<HTMLAnchorElement>(
                `.table-of-contents a[href="#${id}"]`
            );

            link?.closest(".item")?.classList.add("active");
        }, {
            // This helps a LOT with stability
            rootMargin: "0px 0px -60% 0px",
            threshold: [0, 1],
        });

        articleSections.forEach(section => observer.observe(section));
    </script>
</div>
<style is:global>
    .table-of-contents{
        background:var(--color-bg-muted);
        border:1px solid var(--color-border-subtle);
        border-radius: var(--radius-sm);

        .list{
            margin-top:0;

            & ul{ 
                gap: 0;
                
                & a{
                    color:inherit;
                    text-decoration: none;
                }
            }
        }

        .list-item, .item-inner{
            align-items: center;
            display:flex;
            font-size: var(--font-size-sm);
            gap:8px;
            padding:12px 16px;

            &.list-heading{
                font-family: "Poppins";
                font-weight:600;
            }
        }

        .item.active{
            background: var(--color-bg-surface);
            border-left: 2px solid var(--color-border-strong);
            color: var(--color-brand);
        }
    }
</style>