---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Image from "@components/building-blocks/core-elements/image/Image.astro";
import Card from "@components/building-blocks/wrappers/card/Card.astro";
import Split from "@components/building-blocks/wrappers/split/Split.astro";
import Heading from "@core-elements/heading/Heading.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import BlogItem from "@page-sections/blog/featured-blog/BlogItem.astro";
import Grid from "@wrappers/grid/Grid.astro";

import SearchInput from "@components/page-sections/heroes/hero-search/SearchInput.astro";
import { getCollection } from "astro:content";
import FeatureDate from "../FeatureDate.astro";
import Breadcrumb from "../Breadcrumb.astro";
import FeaturedBlogCard from "../FeaturedBlogCard.astro";

const {
  id = "",
  heading = "",
  subtext = "",
  colorScheme = "inherit",
  featuredArticles = [],
  backgroundColor,
  class: className,
  editable = false,
  ...htmlAttributes
} = Astro.props;

const featuredPosts = featuredArticles.map(x => x.replace("/src/content/insights/","").replace(".mdx",""));
const posts = await getCollection('blog', (page) => {
  const id = page.id.replace("/src/content/insights/","").replace(".mdx","")

  return featuredPosts.includes(id);
})
const featuredPost = posts[0];
---

<CustomSection
  class:list={["featured-articles", className]}
  paddingHorizontal="lg"
  paddingVertical={"2xl"}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  maxContentWidth={"2xl"}
  id={id}
  {...htmlAttributes}
>
  <Breadcrumb
      style="color:#757575"
      crumbs={[
        {"Home":"/"},
        {"Insights":"/insights/"}
      ]}
    />
  <Split
    class:list={["featured-blog-split"]}
    label=""
    distributionMode="two-thirds-third"
    minSplitWidth={760}
    verticalAlignment="start"
    gap="xl"
    editable={false}
    data-cloudcannon-ignore
  >
    <Fragment slot="first">
      <Heading
        class="team-grid-heading"
        level="h1"
        size="lg"
        alignX="start"
        data-prop="heading"
        text={heading}
        style="margin-bottom:0"
      />
      <SimpleText
        class="team-grid-subtext"
        size="md"
        alignX="start"
        data-prop="subtext"
      >
        {subtext}
      </SimpleText>
    </Fragment>
    <Fragment slot="second">
      <SearchInput
        style="margin:0"
      />
      <script> 
        document.querySelector("input[name=search]")?.addEventListener("keydown", e => {
            if(e.keyCode == 13){
                const term = e.target.value;
                if(term != "")
                    window.location.href = `/search/?term=${term}`
            }
        })
      </script>
    </Fragment>
  </Split>
  <Split
      class:list={["featured-blog-split"]}
      label=""
      distributionMode="two-thirds-third"
      minSplitWidth={760}
      verticalAlignment="start"
      gap="xl"
      editable={false}
    >
    <Fragment slot="first" editable={false} data-cloudcannon-ignore data-editable={false}>
      <FeaturedBlogCard featuredPost={featuredPost} direction="vertical" />
    </Fragment>
    <Fragment slot="second" editable={false}>
      <Card
        paddingHorizontal="lg"
        paddingVertical="lg"
        colorScheme="inherit"
        backgroundColor="base"
        class:list={["featured-article-list"]}
        data-prop={undefined}
        editable={false}
      >
        <Grid
          class="featured-blog-grid"
          gap="md"
          minItemWidth={350}
          maxItemWidth={400}
          data-children-prop={""}
          layout="start"
        >
          <Heading
            level="h2"
            size="sm"
            alignX="start"
            iconPosition="before"
            text={"Featured Posts"}
            editable={false}
          />
          {
            posts.slice(1).map(async (post: any, index: number) => {
              return (
                <BlogItem
                  post={post}
                  class="featured-blog-item"
                  data-index={index}
                  data-editable={undefined}
                  data-id={undefined}
                  editable={false}
                />
              )
            })
          }
        </Grid>
      </Card>
    </Fragment>
  </Split>
</CustomSection>

<style>
  .featured-article-list{
    box-shadow: 0px 1px 4px 0px rgba(12,12,13,0.1);
    border-radius: var(--radius-xs);
    overflow: hidden;
    height:100%;
  }

  .featured-blog-grid{
    & .heading{
      margin:0;
    }
  }
  
</style>
