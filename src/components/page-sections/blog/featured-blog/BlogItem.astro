---
import Heading from "@core-elements/heading/Heading.astro";
import Card from "@wrappers/card/Card.astro";
import GridItem from "@wrappers/grid/GridItem.astro";
import FeatureDate from "../FeatureDate.astro";

const {
  post,
  editable = false,
  class: className,
  _component,
  ...htmlAttributes
} = Astro.props;

const cardClasses = ["blog-item", className].filter(Boolean).join(" ");
---

<GridItem>
  <Card
    {...htmlAttributes}
    class:list={cardClasses || undefined}
    paddingHorizontal="none"
    paddingVertical="sm"
    rounded={false}
    border={false}
    backgroundColor=""
    link={`/insights/${post.id}`}
  >
    <div class="team-content">
      <Heading class="feature-title" level="h3" size="xs" alignX="start" editable={false}>
        {post.data.title}
      </Heading>
      <FeatureDate post={post} />
    </div>
  </Card>
</GridItem>

<style>
  @layer page-sections {
    .feature-title {
      margin-bottom: var(--spacing-sm);
      margin-top: var(--spacing-sm);
    }

    .blog-item{
      border-top: 1px solid var(--color-border-subtle);
      margin-top:0;

      &:hover{
        :global(.heading-text){
          color:var(--color-bg-brand);
        }
      }

      & .divider{
        margin:0;
      }
    }
  }
</style>
