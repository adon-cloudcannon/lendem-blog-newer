---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import TeamItem from "@page-sections/people/team-grid/TeamItem.astro";
import Grid from "@wrappers/grid/Grid.astro";
import { getCollection } from "astro:content";

const {
  id = "",
  heading = "",
  subtext = "",
  maxContentWidth = "2xl",
  paddingVertical = "4xl",
  colorScheme = "inherit",
  backgroundColor,
  contentBackground,
  verticalOffset = {},
  rounded = false,
  class: className,
  editable = false,
  ...htmlAttributes
} = Astro.props;

// Get team members from collec~tion if useCollection is true, otherwise use teamMembers array
const members = (await getCollection("blog")).map((entry) => ({
      title: entry.data.title,
      description: entry.data.description,
      imageSource: entry.data.image
    }))
---

<CustomSection
  class:list={["team-grid", className]}
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  contentBackground={contentBackground}
  maxContentWidth={"2xl"}
  verticalOffset={verticalOffset}
  rounded={rounded}
  id={id}
  {...htmlAttributes}
>
  <Heading
    class="team-grid-heading"
    level="h2"
    size="lg"
    alignX="center"
    data-prop="heading"
    text={heading}
  />
  <SimpleText
    class="team-grid-subtext"
    size="md"
    alignX="center"
    data-prop="subtext"
  >
    {subtext}
  </SimpleText>
  <Grid
    class="team-grid-grid"
    gap="md"
    minItemWidth={350}
    maxItemWidth={400}
    data-children-prop={""}
    layout="start"
  >
    {
      members.map((member: any, index: number) => (
        <TeamItem
          {...member}
          class="team-grid-item"
          data-index={index}
          data-editable={undefined}
          data-id={undefined}
          editable={false}
        />
      ))
    }
  </Grid>
</CustomSection>

<style is:global>
  @layer page-sections {
    .team-grid-heading {
      margin-bottom: var(--spacing-sm);
    }

    .team-grid-subtext {
      margin-top: 0;
    }

    .team-grid-grid {
      margin-top: var(--spacing-xl);
    }

    .team-grid .card .card-content {
      display: grid;
      grid-template-columns: 1fr;
      align-items: start;
      height: 100%;
    }

    .team-grid .grid-item {
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .team-grid .team-item.card {
      height: 100%;
    }
  }
</style>
