---
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Card from "@wrappers/card/Card.astro";
import GridItem from "@wrappers/grid/GridItem.astro";

const {
  title = "",
  description = "",
  imageSource = "",
  imageAlt = "",
  editable = false,
  class: className,
  _component,
  ...htmlAttributes
} = Astro.props;

const cardClasses = ["team-item", className].filter(Boolean).join(" ");
---

<GridItem>
  <Card
    {...htmlAttributes}
    class:list={cardClasses || undefined}
    paddingHorizontal="none"
    paddingVertical="sm"
    rounded={false}
    border={false}
    backgroundColor=""
  >
    <div class="team-content">
      <Heading
        class="team-name"
        level="h3"
        size="md"
        alignX="start"
        style="margin-bottom: var(--spacing-xs); margin-top: 0;"
        data-prop={editable ? "name" : undefined}
      >
        {title}
      </Heading>
      <SimpleText
        class="team-role"
        size="sm"
        alignX="start"
        style="font-weight: var(--font-weight-bold); margin-bottom: var(--spacing-sm);margin-top: 0;"
        data-prop={editable ? "role" : undefined}
      >
        {description}
      </SimpleText>
    </div>
    <div class="team-image-container">
      <Image
        class="team-image"
        source={imageSource}
        alt={imageAlt || title}
        aspectRatio="square"
        widths={[400, 800]}
        sizes="400px"
        data-prop-src={editable ? "imageSource" : undefined}
        data-prop-alt={editable ? "imageAlt" : undefined}
        slot="before"
      />
    </div>
  </Card>
</GridItem>

<style>
  @layer page-sections {
    
  }
</style>
